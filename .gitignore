# --- Environnements Python ---
.venv/
venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# --- Secrets (ne JAMAIS committer les clés API) ---
.env
credentials/*.client_secret.json
runtime/*token*.json
runtime/*oauth*.json

# --- Données lourdes : vidéos, caches, sorties ---
# On garde les dossiers (via .gitkeep) mais pas leur contenu
input/*
!input/.gitkeep
output/*
!output/.gitkeep
cache/*
!cache/.gitkeep
samples/*
!samples/.gitkeep
assets/music/*
!assets/music/.gitkeep
assets/logo/*
!assets/logo/.gitkeep

# --- Modèles Whisper téléchargés localement ---
models/

# --- Fichiers systèmes ---
.DS_Store
Thumbs.db
desktop.ini

# --- Etat local de l'application ---
runtime/*
!runtime/.gitkeep
runtime/*.pid
logs/*
!logs/.gitkeep
logs/*.log
